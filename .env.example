PORT=5000
MODEL_PATH=artifacts/best_model.pth
IMAGE_SIZE=256
THRESHOLD=0.5
DEVICE=cuda
ENCODER_NAME=resnet34
SKIP_MODEL_LOAD=false

HF_HOME=.hf_cache
HF_HUB_CACHE=.hf_cache/hub
HF_DATASETS_CACHE=.hf_cache/datasets
XDG_CACHE_HOME=.cache
DATA_ROOT=data/processed

HF_DATASET_NAME=blanchon/INRIA-Aerial-Image-Labeling
HF_DATASET_CONFIG=default
HF_MAX_SAMPLES=360
DATASET_SEED=42

ARTIFACTS_DIR=artifacts
BATCH_SIZE=16
LEARNING_RATE=0.0001
EPOCHS=20
NUM_WORKERS=4

SAM_CHECKPOINT=sam_vit_b_01ec64.pth
SAM_MODEL_TYPE=vit_b
SAM_DEVICE=cuda
MIN_MASK_AREA=50
SAM_MAX_IMAGE_SIDE=1024